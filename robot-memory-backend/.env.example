# 服务监听
HOST=127.0.0.1
PORT=8766
LOG_LEVEL=INFO

# HTTPS（推荐给 https 前端页面访问本地服务时启用）
# 先执行：bash scripts/generate_local_certs.sh
SSL_CERTFILE=./certs/127.0.0.1.pem
SSL_KEYFILE=./certs/127.0.0.1-key.pem

# CORS
ALLOW_ORIGINS=https://your-internal-frontend.bytedance.net
ALLOW_METHODS=GET,POST,OPTIONS
ALLOW_HEADERS=Content-Type,Authorization
EXPOSE_HEADERS=
ALLOW_ORIGIN_REGEX=
CORS_MAX_AGE=600

# Mem0 基础配置
MEM0_VECTOR_PROVIDER=qdrant
MEM0_COLLECTION_NAME=robot_led_memory
MEM0_VECTOR_PATH=./data/qdrant
MEM0_HISTORY_DB_PATH=./data/history.db
MEM0_QDRANT_ON_DISK=true
MEM0_INFER=false
MEM0_SUMMARY_MAX_CHARS=1200

# 默认推荐：本地 embedding + 本地 Qdrant
MEM0_EMBEDDER_PROVIDER=huggingface
MEM0_EMBEDDER_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MEM0_EMBEDDING_DIMS=384
MEM0_EMBEDDER_DEVICE=cpu

# 可选：若希望启用 Mem0 的事实抽取 (MEM0_INFER=true)，可接 Ollama 或 OpenAI 兼容接口
# MEM0_LLM_PROVIDER=openai
# MEM0_LLM_MODEL=gpt-4o-mini
# MEM0_OPENAI_BASE_URL=
# MEM0_OPENAI_API_KEY=

# 如果你本机装了 Ollama，也可以改成：
# MEM0_LLM_PROVIDER=ollama
# MEM0_LLM_MODEL=llama3.1:8b
# MEM0_OLLAMA_BASE_URL=http://127.0.0.1:11434
